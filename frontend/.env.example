# Client-visible
NEXT_PUBLIC_STAKE_POOL_ID=
NEXT_PUBLIC_REPUTATION_LEDGER_ID=
NEXT_PUBLIC_XLM_TOKEN_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Server-only: AI scoring (POST /api/score) — Gemini preferred
GEMINI_API_KEY=
# Optional: default gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Alternative: Anthropic (used if GEMINI_API_KEY is unset)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Server-only: secret key (S…) for the account configured as on-chain `verifier` at StakePool::init.
# Generate: cd frontend && npm run keypair — see docs/VERIFIER_KEY.md
STELLAR_VERIFIER_SECRET_KEY=

# Optional: funded testnet G… for /api/metrics (Soroban simulation source account)
# METRICS_SIMULATION_PUBLIC_KEY=
# Same key usable for CI verify script when you want a stable account:
# VERIFY_PUBLIC_KEY=
